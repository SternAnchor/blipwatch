{
  "name": "blipwatch",
  "version": "0.0.0-development",
  "description": "Server-based interface for HALO-based radars.",
  "license": "GPL-3.0-only",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "docker:build": "docker build -t blipwatch:local .",
    "docker:buildx": "docker buildx build --platform linux/amd64,linux/arm64 -t blipwatch:local --load .",
    "debug": "LOG_LEVEL=debug tsx watch src/index.ts",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint .",
    "simulate:radar": "tsx src/sim/radar-simulator.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "pngjs": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/pngjs": "^6.0.5",
    "eslint": "^9.39.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.1",
    "vitest": "^4.0.14"
  }
}
